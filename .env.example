# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Kindle delivery ---
KINDLE_EMAIL=your-kindle-address@kindle.com   # Send-to-Kindle target
SENDER_EMAIL=you@gmail.com                     # must be on Amazon's approved sender list

# --- SMTP (Gmail example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password          # app password, NOT your account password

# --- Adobe ID (needed ONLY during one-time activation, not at runtime) ---
# Run the activation step once; credentials are not stored by the running app.
# ADOBE_EMAIL=you@example.com
# ADOBE_PASSWORD=...
